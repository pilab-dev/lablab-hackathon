# Kraken API Keys (optional for paper trading, required for live)
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# This key is required for fetching news!
PRISM_API_KEY=prism_sk_blablabla_changeme

# Trading Mode: paper | live
# Default: paper (safe, no real money)
TRADING_MODE=paper

# Trading Pairs (comma-separated)
TRADE_PAIRS=BTCUSD,ETHUSD

# Decision engine interval
TRADE_INTERVAL=30s

# Minimum confidence threshold for trades (0.0 - 1.0)
CONFIDENCE_THRESHOLD=0.6

# Minimum seconds between trades on same pair
TRADE_COOLDOWN=60

# Ollama Configuration
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# InfluxDB Configuration
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=admin123
INFLUXDB_ORG=kraken-trader
INFLUXDB_BUCKET=market-data

# ChromaDB Configuration
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=news-embeddings

# Dashboard
DASHBOARD_PORT=8080

# Logging
LOG_LEVEL=info

# Redis Configuration
REDIS_URL=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ERC-8004 Blockchain Configuration
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
SEPOLIA_CHAIN_ID=11155111
OPERATOR_PRIVATE_KEY=  # 64 hex chars, no 0x prefix
AGENT_PRIVATE_KEY=   # 64 hex chars, no 0x prefix
AGENT_ID=
AGENT_REGISTRY_ADDRESS=0x97b07dDc405B0c28B17559aFFE63BdB3632d0ca3
HACKATHON_VAULT_ADDRESS=0x0E7CD8ef9743FEcf94f9103033a044caBD45fC90
RISK_ROUTER_ADDRESS=0xd6A6952545FF6E6E6681c2d15C59f9EB8F40FdBC
REPUTATION_REGISTRY_ADDRESS=0x423a9904e39537a9997fbaF0f220d79D7d545763
VALIDATION_REGISTRY_ADDRESS=0x92bF63E5C7Ac6980f237a7164Ab413BE226187F1
GAS_LIMIT=300000
GAS_PRICE_GWEI=2
